# --- Supabase (mesmos valores do apps/web/.env.local) ---
EXPO_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# --- API tRPC (o app web serve o backend) ---
# Produção: https://<seu-projeto>.vercel.app
# Dev local: http://<IP-da-sua-máquina>:3000 (celular não enxerga "localhost")
EXPO_PUBLIC_API_URL="https://rise.vercel.app"
