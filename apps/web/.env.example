# --- Supabase (Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# --- Banco (server-side, usado pelo route handler tRPC / @rise/db) ---
# Runtime serverless: usar o pooler (porta 6543) com prepare:false.
DATABASE_URL="postgresql://postgres:[SENHA]@db.[PROJECT-REF].supabase.co:6543/postgres"

# service_role (NUNCA expor no cliente) — para mutações server-side de progresso/economia.
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# --- Cron (/api/cron: estipêndio mensal de Faíscas + prune da outbox) ---
# Segredo forte. A Vercel Cron envia "Authorization: Bearer $CRON_SECRET".
# Sem este valor o endpoint recusa toda chamada (nunca roda aberto).
CRON_SECRET="[GERAR-SEGREDO-FORTE]"
